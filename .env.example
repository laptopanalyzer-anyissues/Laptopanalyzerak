# ─────────────────────────────────────────────────────────────
# Environment variables for Laptop Analyzer (Vite, build-time)
# Copy this file to `.env` and fill in the values.
#
# NOTE: Only the *anon / publishable* Supabase key belongs here.
# It is public by design (it ships in the browser bundle and is
# protected by Row Level Security). NEVER put the SUPABASE service-role
# key or any real secret in this file — those live only in the Supabase
# dashboard as Edge Function secrets.
# ─────────────────────────────────────────────────────────────

# Supabase project URL
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon / publishable key (public — safe for the client)
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# Supabase project ref id
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
