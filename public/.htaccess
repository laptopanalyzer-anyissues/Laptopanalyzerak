# Apache SPA Fallback for React Router
# Ensures all virtual routes serve index.html with 200 OK status

# ── Block access to sensitive files (defense in depth) ──
# Deny any dotfile (.env, .git, .htaccess, .htpasswd, etc.)
<FilesMatch "(^\.|/\.)">
  Require all denied
</FilesMatch>

# Deny source/config files that should never be served if present.
# (Runtime assets are .js/.css/.json — those are intentionally NOT listed here.)
<FilesMatch "\.(env|ini|log|sh|bak|sql|toml|lock|mjs|ts|tsx|map)$">
  Require all denied
</FilesMatch>

# Disable directory listing
Options -Indexes

# Suppress server version/signature in headers and error pages
ServerSignature Off

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Proxy sitemap.xml to PHP handler (must be BEFORE the SPA catch-all)
  RewriteRule ^sitemap\.xml$ /sitemap.php [L]
  
  # Route all /blog requests through PHP handler (same proven pattern as sitemap.php)
  RewriteRule ^blog(/.*)?$ /blog-render.php [L]
  
  # Don't rewrite files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Rewrite everything else to index.html
  RewriteRule ^(.*)$ /index.html [L,QSA]
</IfModule>

# Ensure proper MIME types
<IfModule mod_mime.c>
  AddType text/html .html
  AddType application/javascript .js
  AddType text/css .css
</IfModule>

# Allow all search engine bots
<IfModule mod_headers.c>
  Header set X-Robots-Tag "index, follow"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set Permissions-Policy "camera=(self), microphone=(self), geolocation=(), payment=(), usb=(self), bluetooth=(self)"
  Header set X-DNS-Prefetch-Control "on"
</IfModule>
